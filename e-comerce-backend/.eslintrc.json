{
  "parser": "@typescript-eslint/parser",
  "parserOptions": {
    "ecmaVersion": 2022,
    "sourceType": "module"
  },
  "plugins": ["@typescript-eslint"],
  "extends": [
    "eslint:recommended",
    "plugin:@typescript-eslint/recommended",
    "prettier"
  ],
  "root": true,
  "env": {
    "node": true,
    "es2022": true
  },
  "ignorePatterns": [
    "dist",
    "node_modules"
  ],
  "rules": {
    "@typescript-eslint/no-namespace": "off"
  }
}

